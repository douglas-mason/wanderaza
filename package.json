{
  "name": "wanderaza",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm --filter './apps/*' -r --parallel dev",
    "build": "pnpm -r build",
    "type-check": "pnpm -r type-check",
    "db:generate": "pnpm --filter @wanderaza/db db:generate",
    "db:migrate": "pnpm --filter @wanderaza/db db:migrate",
    "db:studio": "pnpm --filter @wanderaza/db db:studio"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
